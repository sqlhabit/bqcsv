#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "Working tree has uncommitted changes. Commit or stash them first." >&2
  exit 1
fi

VERSION="$(python3 - <<'PY'
import pathlib
import re
import sys

pyproject = pathlib.Path("pyproject.toml").read_text()
init = pathlib.Path("src/__init__.py").read_text()
match = re.search(r'^version = "([^"]+)"', pyproject, re.M)
if not match:
    sys.exit("Could not read version from pyproject.toml")
pyproject_version = match.group(1)
match = re.search(r'__version__ = "([^"]+)"', init)
if not match:
    sys.exit("Could not read __version__ from src/__init__.py")
init_version = match.group(1)
if pyproject_version != init_version:
    sys.exit(
        f"Version mismatch: pyproject.toml={pyproject_version}, "
        f"src/__init__.py={init_version}"
    )
print(pyproject_version)
PY
)"

echo "Releasing bqcsv $VERSION"

python3 -m unittest discover -s tests -v

"$ROOT/bin/build"

twine upload dist/*

git tag "v$VERSION"
git push origin HEAD "v$VERSION"

echo "Released v$VERSION to PyPI"
